# FlowCart environment template
# Copy this file to `.env.local` and fill in real values.

# Required Airia live config
AIRIA_API_URL=
AIRIA_API_KEY=
AIRIA_AGENT_ID=
# Set either AIRIA_AGENT_ID or AIRIA_AGENT_GUID.
AIRIA_AGENT_GUID=

# Optional Airia request tuning
AIRIA_API_METHOD=POST
AIRIA_API_BODY_SHAPE=compat
AIRIA_API_TIMEOUT_MS=30000
AIRIA_API_AUTH_HEADER_NAME=Authorization
AIRIA_API_AUTH_HEADER_PREFIX=Bearer
AIRIA_API_KEY_HEADER_NAME=x-api-key
AIRIA_API_HEADERS_JSON=
AIRIA_EXTRA_HEADERS_JSON=

# Shopify live config
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Instagram live config
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ENABLED=true

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local persistence override; Vercel falls back to a temp storage root when this is unset.
MERCHFLOW_STORAGE_DIR=

# Local script helpers
BASE_URL=http://127.0.0.1:3100
SCRIPT_TIMEOUT_MS=10000
